# EditorConfig for test projects
# Override root .editorconfig to allow 'var' everywhere without warnings

root = false

[*.cs]
# Allow var everywhere - no warnings or suggestions
# IDE0007: Use implicit type
dotnet_diagnostic.IDE0007.severity = none

# IDE0008: Use explicit type
dotnet_diagnostic.IDE0008.severity = none

# Prefer 'var' when the type is apparent
csharp_style_var_when_type_is_apparent = true:none

# Prefer 'var' for built-in types (int, string, bool, etc.)
csharp_style_var_for_built_in_types = true:none

# Prefer 'var' elsewhere (when the type is not immediately evident)
csharp_style_var_elsewhere = true:none
